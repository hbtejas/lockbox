# --- Lockbox Environment Variables ---

# DATABASE (Vercel Postgres or any PostgreSQL)
DATABASE_URL="postgres://user:password@host:port/dbname?sslmode=require"

# NEXTAUTH (Authentication)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-generated-secret-key-here" # Generate with: openssl rand -base64 32

# GOOGLE OAUTH
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ANTHROPIC (Claude AI)
ANTHROPIC_API_KEY="sk-ant-..."

# EMAIL (Resend)
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="noreply@lockbox.app"

# APP SETTINGS
NEXT_PUBLIC_APP_NAME="Lockbox"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ADMIN SEED
ADMIN_EMAIL="admin@lockbox.app"
ADMIN_PASSWORD="a-very-strong-password-123!"
